NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tukapi?schema=public
JWT_SECRET=change-this-secret-to-a-long-random-value
JWT_ACCESS_SECRET=change-this-access-secret-to-a-long-random-value
JWT_REFRESH_SECRET=change-this-refresh-secret-to-a-long-random-value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
CORS_ORIGIN=*
API_PREFIX=/api/v1
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
LOG_LEVEL=info
SWAGGER_ENABLED=true
