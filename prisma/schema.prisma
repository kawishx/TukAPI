generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  NATIONAL_COMMAND
  PROVINCIAL_COMMANDER
  STATION_COMMANDER
  FIELD_OFFICER
  ANALYST
}

enum TukTukStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

model Province {
  id           String         @id @default(cuid())
  name         String
  code         String         @unique
  districts    District[]
  stations     PoliceStation[]
  tukTuks      TukTuk[]
  drivers      Driver[]
  users        User[]
  locationPings LocationPing[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([name])
}

model District {
  id            String          @id @default(cuid())
  name          String
  code          String          @unique
  provinceId    String
  province      Province        @relation(fields: [provinceId], references: [id])
  stations      PoliceStation[]
  tukTuks       TukTuk[]
  users         User[]
  locationPings LocationPing[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([provinceId])
  @@index([name])
}

model PoliceStation {
  id            String          @id @default(cuid())
  name          String
  code          String          @unique
  address       String
  provinceId    String
  districtId    String
  province      Province        @relation(fields: [provinceId], references: [id])
  district      District        @relation(fields: [districtId], references: [id])
  tukTuks       TukTuk[]
  drivers       Driver[]
  users         User[]
  locationPings LocationPing[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([provinceId])
  @@index([districtId])
  @@index([name])
}

model Driver {
  id            String        @id @default(cuid())
  fullName      String
  nationalId    String        @unique
  licenseNumber String        @unique
  phoneNumber   String?
  address       String?
  provinceId    String?
  stationId     String?
  province      Province?     @relation(fields: [provinceId], references: [id])
  station       PoliceStation? @relation(fields: [stationId], references: [id])
  tukTuks       TukTuk[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([provinceId])
  @@index([stationId])
  @@index([fullName])
}

model TrackingDevice {
  id            String        @id @default(cuid())
  serialNumber  String        @unique
  imei          String        @unique
  status        DeviceStatus  @default(ACTIVE)
  installedAt   DateTime?
  lastSeenAt    DateTime?
  tukTuk        TukTuk?
  locationPings LocationPing[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

model TukTuk {
  id                 String          @id @default(cuid())
  registrationNumber String          @unique
  color              String
  model              String
  status             TukTukStatus    @default(ACTIVE)
  provinceId         String?
  districtId         String?
  stationId          String?
  driverId           String?
  deviceId           String?         @unique
  province           Province?       @relation(fields: [provinceId], references: [id])
  district           District?       @relation(fields: [districtId], references: [id])
  station            PoliceStation?  @relation(fields: [stationId], references: [id])
  driver             Driver?         @relation(fields: [driverId], references: [id])
  device             TrackingDevice? @relation(fields: [deviceId], references: [id])
  locationPings      LocationPing[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([provinceId])
  @@index([districtId])
  @@index([stationId])
  @@index([driverId])
  @@index([status])
}

model User {
  id          String         @id @default(cuid())
  fullName    String
  email       String         @unique
  badgeNumber String         @unique
  passwordHash String
  role        UserRole
  isActive    Boolean        @default(true)
  provinceId  String?
  districtId  String?
  stationId   String?
  province    Province?      @relation(fields: [provinceId], references: [id])
  district    District?      @relation(fields: [districtId], references: [id])
  station     PoliceStation? @relation(fields: [stationId], references: [id])
  lastLoginAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([role])
  @@index([provinceId])
  @@index([districtId])
  @@index([stationId])
}

model LocationPing {
  id            String         @id @default(cuid())
  tukTukId      String
  deviceId      String?
  provinceId    String?
  districtId    String?
  stationId     String?
  latitude      Decimal        @db.Decimal(10, 7)
  longitude     Decimal        @db.Decimal(10, 7)
  speedKph      Decimal?       @db.Decimal(6, 2)
  heading       Decimal?       @db.Decimal(6, 2)
  recordedAt    DateTime
  receivedAt    DateTime       @default(now())
  tukTuk        TukTuk         @relation(fields: [tukTukId], references: [id])
  device        TrackingDevice? @relation(fields: [deviceId], references: [id])
  province      Province?      @relation(fields: [provinceId], references: [id])
  district      District?      @relation(fields: [districtId], references: [id])
  station       PoliceStation? @relation(fields: [stationId], references: [id])
  createdAt     DateTime       @default(now())

  @@index([tukTukId, recordedAt])
  @@index([deviceId, recordedAt])
  @@index([provinceId, recordedAt])
  @@index([districtId, recordedAt])
  @@index([stationId, recordedAt])
}

